# Production Environment Variables
# Copy this file to .env.production and update with actual values

# Backend API URL (REQUIRED for GitHub Pages deployment)
# Options:
# 1. External API service (Railway, Render, etc.)
#    Example: VITE_API_BASE_URL=https://your-backend.railway.app/api/v1
# 2. Leave empty to use mock data or same-origin API
#    Example: VITE_API_BASE_URL=
VITE_API_BASE_URL=

# Environment
VITE_NODE_ENV=production
